{
  "expo": {
    "name": "Inspect AI",
    "slug": "inspect-ai-mobile",
    "scheme": "inspectai",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1c4280"
    },
    "ios": {
      "bundleIdentifier": "com.inspectai.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Capture inspection photos for reports.",
        "NSPhotoLibraryUsageDescription": "Attach existing photos to inspections."
      }
    },
    "android": {
      "package": "com.inspectai.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1c4280"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [
            {
              "scheme": "com.googleusercontent.apps.1058024176284-5j44ndq836lpsmkqea5l1kjauetb460o"
            }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Inspect AI to access your camera."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:8787",
      "googleWebClientId": "1058024176284-cubmrr92eatljpr1vfhsklk8dg8ih6e9.apps.googleusercontent.com",
      "googleAndroidClientId": "1058024176284-5j44ndq836lpsmkqea5l1kjauetb460o.apps.googleusercontent.com",
      "googleIosClientId": "",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "41dc96e8-436a-4789-b7e5-19193f5e94dc"
      }
    },
    "owner": "zolidavis"
  }
}
